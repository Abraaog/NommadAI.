# Groq API Keys (Balanced across 4 different accounts for high-throughput)
GROQ_API_KEY=gsk_...

# Key Account 1
GROQ_KEY_CLEANER=gsk_...
GROQ_KEY_CLASSIFIER=gsk_...

# Key Account 2
GROQ_KEY_ANALYST=gsk_...
GROQ_KEY_STRATEGIST=gsk_...

# Key Account 3
GROQ_KEY_BRAIN=gsk_...
GROQ_KEY_RESPONSE=gsk_...

# Key Account 4
GROQ_KEY_MISSION=gsk_...
GROQ_KEY_CHECKIN=gsk_...

# Default model used for most agents
GROQ_MODEL=llama-3.3-70b-versatile

# AI Toggle (set to 'false' to disable all AI agents during development)
# AI_ENABLED=true
