{
  "name": "nommad-ai-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "grouter": "cd apps/grouter && bun index.ts serve fg",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "fix-checkin": "node scripts/fix-checkin.js"
  }
}
